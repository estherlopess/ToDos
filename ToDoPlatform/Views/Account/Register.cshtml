@model RegisterVM
@{
Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initialscale=1.0">
<title>ToDos Platform - Registro</title>
<link rel="stylesheet" href="~/css/login.css" />
</head>
<body/>
<div class="login-container">
<div class="login-card">
<div class="logo">ToDos Platform</div>
<h1 class="form-title">Criar nova conta</h1>
<form id="registerForm" asp-action="Register" method="post">
@Html.AntiForgeryToken()
<!-- Name, Email, Password, ConfirmPassword e Terms -->
<!-- (campos com asp-for, asp-validation-for e .errormessage) -->
<div class="terms">
<div>
<input type="checkbox" asp-for="Terms" />
<label asp-for="Terms">Eu concordo com os <a
href="#">Termos de Serviço</a> e <a href="#">Política de
Privacidade</a></label>
</div>
<span class="error-message" style="display: block;"
asp-validation-for="Terms"></span>
</div>
<button type="submit" class="btn-login"
disabled="@(TempData["Success"] != null)">Criar
Conta</button>
<div class="register-link">
Já tem uma conta? <a asp-action="Login">Faça
login</a>
</div>
</form>
</div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<partial name="_ValidationScriptsPartial" />
<partial name="_Notification" />
<script>
if ('@TempData["Success"]' !== "") {
showMessage(null, '@TempData["Success"]', 3000,
'/Account/Login');
}
if ('@TempData["Failure"]' !== "") {
showMessage("warning", '@TempData["Failure"]', 5000, null);
}
$('#registerForm').on('submit', function (e) {
if (!$(this).valid()) {
e.preventDefault(); return false;
}
if (!$('#Terms').is(':checked')) {
e.preventDefault(); $('#Terms').focus();
showMessage('warning', 'Você deve aceitar os termos para continuar', 3000, null);
return false;
}
});
</script>